# ============================================================================
# IAD Portale - Environment variables
# ============================================================================
# COPIA QUESTO FILE IN .env.local E COMPILA I VALORI REALI (da 1Password)
# NON COMMITTARE MAI .env.local SU GIT
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE (database + auth + storage)
# ----------------------------------------------------------------------------
# Trovi questi valori in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://nxzetjvbomlyryplodro.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGci..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci..." # ⚠️ SEGRETISSIMA, solo server-side

# ----------------------------------------------------------------------------
# DATABASE (Prisma connections)
# ----------------------------------------------------------------------------
# Dashboard → Connect → ORMs → Prisma
# Sostituisci [YOUR-PASSWORD] con la password DB salvata in 1Password
DATABASE_URL="postgresql://postgres.nxzetjvbomlyryplodro:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.nxzetjvbomlyryplodro:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ----------------------------------------------------------------------------
# RESEND (email transazionali)
# ----------------------------------------------------------------------------
# Crea account su https://resend.com, verifica il dominio irpiniaartedanza.it
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@irpiniaartedanza.it"
RESEND_FROM_NAME="IAD Irpinia Arte Danza"

# ----------------------------------------------------------------------------
# APP CONFIGURATION
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"  # produzione → https://area.irpiniaartedanza.it
NEXT_PUBLIC_APP_NAME="IAD Portale"

# Timezone operativo (non cambiare)
TZ="Europe/Rome"

# ----------------------------------------------------------------------------
# ASD IDENTITY (fallback statici, sovrascrivibili da BrandSettings DB)
