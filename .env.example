# ============================================================================
# IAD Portale - Environment variables template
# ============================================================================
# Copia questo file come .env.local e compila con valori reali (da 1Password)
# NON committare mai .env.local su Git
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE (database + auth + storage)
# ----------------------------------------------------------------------------
# Trovi questi valori in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"  # SEGRETISSIMA, solo server-side

# ----------------------------------------------------------------------------
# DATABASE (Prisma connections)
# ----------------------------------------------------------------------------
# Dashboard → Connect → ORMs → Prisma
# Sostituisci [YOUR-PASSWORD] con la password DB salvata in 1Password
DATABASE_URL="postgresql://postgres.YOUR-PROJECT:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ----------------------------------------------------------------------------
# RESEND (email transazionali)
# ----------------------------------------------------------------------------
# Crea account su https://resend.com, verifica il dominio proprio
RESEND_API_KEY="re_your_api_key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_FROM_NAME="Your Organization Name"

# ----------------------------------------------------------------------------
# APP CONFIGURATION
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"  # produzione → https://your-domain.com
NEXT_PUBLIC_APP_NAME="Your App Name"

# Timezone operativo
TZ="Europe/Rome"

# ----------------------------------------------------------------------------
# ORGANIZATION IDENTITY (fallback statici, sovrascrivibili da BrandSettings DB)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_ASD_NAME="Your Organization Name"
NEXT_PUBLIC_ASD_ADDRESS="Your Organization Address"
NEXT_PUBLIC_ASD_FISCAL_CODE="YOUR_FISCAL_CODE"
NEXT_PUBLIC_ASD_EMAIL="info@yourdomain.com"

# ----------------------------------------------------------------------------
# MONITORING (attiva in produzione)
# ----------------------------------------------------------------------------
# SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""

# ----------------------------------------------------------------------------
# CRON SECURITY (per endpoint Vercel Cron)
# ----------------------------------------------------------------------------
CRON_SECRET="generate-with-openssl-rand-hex-32"

# ----------------------------------------------------------------------------
# ADMIN BOOTSTRAP (per creare il primo admin via seed)
# ----------------------------------------------------------------------------
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_FIRST_NAME="AdminFirstName"
ADMIN_LAST_NAME="AdminLastName"
ADMIN_SUPABASE_UUID="uuid-from-supabase-auth-users"

# ----------------------------------------------------------------------------
# V2 — SumUp (non attivo nell'MVP, lascialo vuoto)
# ----------------------------------------------------------------------------
# SUMUP_CLIENT_ID=""
# SUMUP_CLIENT_SECRET=""
# SUMUP_MERCHANT_CODE=""
